  <decision name="islive" id="_13797711-0F0C-44DD-A0B0-10881DDAE876">
    <variable name="islive" id="_4C0FA377-BC2E-401D-8E35-DDA72BD1F41F" typeRef="number" />
    <informationRequirement id="_ED782CA6-1930-4D18-AB75-C192AF36029E">
      <requiredInput href="#_72F5FFF8-DF00-4DB5-BF0F-09166C05280F" />
    </informationRequirement>
    <informationRequirement id="_A2A1E4A2-DCE4-4B71-B0D9-76DF223A5CFB">
      <requiredDecision href="#_02C39356-0078-4266-AD5F-E589A4B0BB02" />
    </informationRequirement>
    <literalExpression id="_7ACCFF4A-413A-40C5-AAA8-11CCC2AB5857" typeRef="number" label="islive">
      <text>count(Request.tbl_tradelines [tl_closed_date in ClosedDate])</text>
    </literalExpression>
  </decision>
  <decision name="UnSecureLiveLoan" id="_BD52E439-BE03-490B-BD41-B8A010561F91">
    <variable name="UnSecureLiveLoan" id="_813941B6-6388-4DA5-A1FE-45302B611F84" typeRef="Any" />
    <informationRequirement id="_D0654BB4-D2B3-414A-B873-39F0C72BAF01">
      <requiredInput href="#_72F5FFF8-DF00-4DB5-BF0F-09166C05280F" />
    </informationRequirement>
    <literalExpression id="_5C9692AB-FB31-4961-95E3-DBA7D51AE129" typeRef="Any" label="UnSecureLiveLoan">
      <text>[&quot;BUSINESSLOAN&quot;,&quot;CONSUMERLOAN&quot;, &quot;EDUCATIONLOAN&quot;, &quot;LOANONCREDITCARD&quot;, &quot;MICROFINANCEHOUSINGLOAN&quot;, &quot;PERSONALLOAN&quot;, &quot;MUDRALOANSSHISHUKISHORTARUN&quot;, &quot;OTHER&quot;, &quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;]</text>
    </literalExpression>
  </decision>
  <decision name="Count of Unsec" id="_5D64079A-2DEE-4FD1-BE7B-40D94E815B47">
    <variable name="Count of Unsec" id="_1F83DE9C-592F-4793-8B10-1A48B86A1244" typeRef="number" />
    <informationRequirement id="_B99445F8-8B9C-4819-84C7-C33DCF02AE52">
      <requiredDecision href="#_BD52E439-BE03-490B-BD41-B8A010561F91" />
    </informationRequirement>
    <informationRequirement id="_1C5824FB-E590-4DCD-BBA6-84F7648A3D85">
      <requiredInput href="#_72F5FFF8-DF00-4DB5-BF0F-09166C05280F" />
    </informationRequirement>
    <informationRequirement id="_5B0C683A-6757-431F-9C54-4A54F221E613">
      <requiredDecision href="#_02C39356-0078-4266-AD5F-E589A4B0BB02" />
    </informationRequirement>
    <knowledgeRequirement id="_F3097E81-B856-4174-98A9-80D2A2EC4F9A">
      <requiredKnowledge href="#_7AA3BB9D-38D4-4952-A4AD-1B8C4B325BC3" />
    </knowledgeRequirement>
    <literalExpression id="_47C41A2C-39D6-4D84-BB9F-F16A4FC414B9" typeRef="number" label="Count of Unsec">
      <text>count(for t in Request.tbl_tradelines return isunsecuredlive(t))</text>
    </literalExpression>
  </decision>
  <decision name="ClosedDate" id="_02C39356-0078-4266-AD5F-E589A4B0BB02">
    <variable name="ClosedDate" id="_17DD9E4B-66E0-4E09-9840-8E36DF9ADD47" typeRef="Any" />
    <informationRequirement id="_262FADC1-7435-45A7-8EE6-35E149CCB5F5">
      <requiredInput href="#_72F5FFF8-DF00-4DB5-BF0F-09166C05280F" />
    </informationRequirement>
    <literalExpression id="_5ACF043E-3E88-49CE-B616-04F2DEB7497C" typeRef="Any" label="ClosedDate">
      <text>[&quot;01/01/1900 00:00:00&quot;, &quot;null&quot;, null, &quot;&quot;]</text>
    </literalExpression>
  </decision>
  <decision name="TotalOverdue" id="_2202D674-19D5-4CC1-8AFF-ABB0DF2D6781">
    <variable name="TotalOverdue" id="_59C0C70B-43FF-4983-BA21-E1D687EAC2B4" typeRef="number" />
    <informationRequirement id="_EC93BD3B-2C57-4436-B2C6-CFBECBD3E3F6">
      <requiredInput href="#_72F5FFF8-DF00-4DB5-BF0F-09166C05280F" />
    </informationRequirement>
    <knowledgeRequirement id="_F0DF4E3E-B969-4AB4-A308-FEB9E5EEFFA6">
      <requiredKnowledge href="#_2C0B32B2-CF17-4338-B4E6-BF9F1298A1A9" />
    </knowledgeRequirement>
    <literalExpression id="_991F5FDC-5903-4078-975B-85BC191C490D" typeRef="number" label="TotalOverdue">
      <text>sum(for t in Request.tbl_tradelines return getoverdueamount(t))</text>
    </literalExpression>
  </decision>
  <businessKnowledgeModel name="isunsecuredlive" id="_7AA3BB9D-38D4-4952-A4AD-1B8C4B325BC3">
    <variable name="isunsecuredlive" id="_B507C843-55A1-4B85-9FDC-D978E6E0344D" typeRef="boolean" />
    <encapsulatedLogic label="isunsecuredlive" typeRef="boolean" id="_27DBD8E1-19DC-46BE-968A-C5601DFFCC07" kind="FEEL">
      <formalParameter id="_678C04B7-7FEC-4D06-8E1E-AC1FC4364631" name="Tradeline" typeRef="Tradeline" />
      <literalExpression id="_D6AAE23E-9F8F-45DA-83BB-69FEF2C5A1BC" typeRef="boolean" label="Return">
        <text>Tradeline.tl_acct_type in [&quot;BUSINESSLOAN&quot;,&quot;CONSUMERLOAN&quot;, &quot;EDUCATIONLOAN&quot;, &quot;LOANONCREDITCARD&quot;, &quot;MICROFINANCEHOUSINGLOAN&quot;, &quot;PERSONALLOAN&quot;, &quot;MUDRALOANSSHISHUKISHORTARUN&quot;, &quot;OTHER&quot;, &quot;PRIMEMINISTERJAANDHANYOJANAOVERDRAFT&quot;] and Tradeline.tl_closed_date in [&quot;01/01/1900 00:00:00&quot;, &quot;null&quot;, null, &quot;&quot;]</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="getoverdueamount" id="_2C0B32B2-CF17-4338-B4E6-BF9F1298A1A9">
