  <decision name="Item Totals" id="_50546900-8B24-48ED-93D2-8D76B62F1AD2">
    <variable name="Item Totals" id="_29758B5D-92F1-401F-AACE-3ADE7F94437E" typeRef="ItemTotal" />
    <informationRequirement id="_414F7C67-C11F-4D51-A98B-0E3D627B8FE2">
      <requiredInput href="#_3B2F6B42-77E0-4116-9894-209BCB1C3BB4" />
    </informationRequirement>
    <knowledgeRequirement id="_AF5E98D9-DA1F-45F4-8500-46929B942C98">
      <requiredKnowledge href="#_DA8526FD-46B9-4CD1-BC32-DE574FAC0222" />
    </knowledgeRequirement>
    <for id="_AD1FE082-2203-435F-89CC-F52E28B6DE01" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_ACF33BDF-47EE-4BC6-B095-459E6CE3EB30">
        <literalExpression id="_21BAD145-07F9-4A43-9EAD-CD6540B88616" label="Expression Name">
          <text>PurchaseRequest.items</text>
        </literalExpression>
      </in>
      <return id="_2BD5FE58-C21F-476F-BD74-A62FC394213A">
        <literalExpression id="_6AD204F7-8965-4202-B857-F4A082AEA52C" label="Expression Name">
          <text>Calculate Item Total(item)</text>
        </literalExpression>
      </return>
    </for>
  </decision>
  <decision name="Total Procurement Cost" id="_88B59FCA-D8EC-490E-BE31-66FD6EE97045">
    <variable name="Total Procurement Cost" id="_C7C0C9A5-8BE8-4A34-BB5F-7DC31F4043C4" typeRef="number" />
    <informationRequirement id="_CD2DF254-5838-49B9-B53C-CFD07B14CC6C">
      <requiredDecision href="#_50546900-8B24-48ED-93D2-8D76B62F1AD2" />
    </informationRequirement>
    <literalExpression id="_F3406B08-15F5-4943-BE37-0D3C17C58F48" typeRef="number" label="Total Procurement Cost">
      <text>sum(Item Totals)</text>
    </literalExpression>
  </decision>
  <decision name="Eligible Vendors" id="_71041D96-E472-43EA-ADC7-C5B821E43B42">
    <variable name="Eligible Vendors" id="_10356F1C-2CE8-4FB5-A6F8-4E6D4ACD25C2" typeRef="VendorList" />
    <informationRequirement id="_21DE18E8-CB1E-44FF-A4AC-B8BBB5566902">
      <requiredInput href="#_079D75CB-3E7F-4FB2-8E90-5314C9D6F4F5" />
    </informationRequirement>
    <informationRequirement id="_59DA07C0-FF51-47DE-950B-EDAC6FB77FA7">
      <requiredInput href="#_D37176B8-CF49-4709-8EBD-9E410B741425" />
    </informationRequirement>
    <knowledgeRequirement id="_B9589D5B-9344-465C-8921-04874F28F45F">
      <requiredKnowledge href="#_6F84A8DC-6D80-4597-BB56-4E62D6139624" />
    </knowledgeRequirement>
    <filter id="_61AD0D2B-D84A-43A5-B1FE-799F6B77090B" typeRef="VendorList" label="Eligible Vendors">
      <in id="_23B9110A-7312-4BD1-8F45-BC58A9034564">
        <literalExpression id="_DD7F19D7-03A6-4F22-8A1F-E4C318225F14" label="Expression Name">
          <text>Vendors</text>
        </literalExpression>
      </in>
      <match id="_9BCEA23C-41E9-44F0-9208-2DF1D7C5BBF2">
        <literalExpression id="_7BEB9357-98E8-487F-A042-28C6C26AA894" label="Expression Name">
          <text>Is Vendor Eligible (item.Policies)</text>
        </literalExpression>
      </match>
    </filter>
  </decision>
  <businessKnowledgeModel name="Calculate Item Total" id="_DA8526FD-46B9-4CD1-BC32-DE574FAC0222">
    <variable name="Calculate Item Total" id="_CD690C6B-B9CF-43FB-BA5E-7FFC6B6A5A00" typeRef="number" />
    <encapsulatedLogic label="Calculate Item Total" typeRef="number" id="_4010B95F-FD01-4F52-A918-7C11CE715B7B" kind="FEEL">
      <formalParameter id="_5E29AEEB-0D3A-433C-AADC-6BF039671017" name="item" typeRef="Item" />
      <literalExpression id="_612F6906-9DA9-4E7A-8538-C20EDA1B60D5" typeRef="number" label="Return">
        <text>if item.quantity = null or item.unitPrice = null then 0 else item.quantity * item.unitPrice</text>
      </literalExpression>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Is Vendor Eligible" id="_6F84A8DC-6D80-4597-BB56-4E62D6139624">
    <variable name="Is Vendor Eligible" id="_A3C32239-A767-40D6-BD57-DEF4B4307DC4" typeRef="boolean" />
    <encapsulatedLogic label="Is Vendor Eligible" typeRef="boolean" id="_EA453A49-7D2A-4552-8B8B-CFB4B99D2483" kind="FEEL">
      <formalParameter id="_CF453686-ECBE-460B-A797-7CF637EC311E" name="Vendor" typeRef="Vendor" />
      <formalParameter id="_4221E1DC-060E-4C00-9950-56726D654B68" name="Policies" typeRef="Policies" />
      <conditional id="_28EC1B96-3827-46D4-AB81-969955E77970" label="Return">
        <if id="_59B263C6-21E8-4C6E-95EB-3D5E5C726AB8">
          <literalExpression id="_9738FBF7-6DC3-4555-A749-DE2B474822E7" label="Expression Name">
            <text>Vendor.complianceScore &gt;= Policies.minComplianceScore and Vendor.deliveryDays &lt;= Policies.maxDeliveryDays</text>
          </literalExpression>
        </if>
        <then id="_2E5CF49D-CE61-4658-ACE7-C392A31D8BFC">
          <literalExpression id="_8F2A374E-08C3-4AD7-B4E2-A4492DD76680" label="Expression Name">
            <text>true</text>
          </literalExpression>
        </then>
        <else id="_EBFACF06-88F2-47CC-A8EA-303338FFC949">
          <literalExpression id="_B6FB6B63-69D5-4312-AAF0-EFCB115604C3" label="Expression Name">
            <text>false</text>
          </literalExpression>
        </else>
      </conditional>
    </encapsulatedLogic>
  </businessKnowledgeModel>
