    <for id="_AD1FE082-2203-435F-89CC-F52E28B6DE01" typeRef="ItemTotal" label="Item Totals" iteratorVariable="item">
      <in id="_ACF33BDF-47EE-4BC6-B095-459E6CE3EB30">
        <literalExpression id="_21BAD145-07F9-4A43-9EAD-CD6540B88616" label="Expression Name">
