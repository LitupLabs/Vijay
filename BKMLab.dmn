  <decision name="Risk Category" id="_7D4DAFFB-973C-45E0-95B3-D9B541C8C55C">
    <variable name="Risk Category" id="_422838F3-8481-4A20-A44B-4877AF850C18" typeRef="RiskCategory" />
    <informationRequirement id="_B8F87ACD-F389-41EE-8197-410225F46DE9">
      <requiredInput href="#_0AC9F0FA-AA7C-4AA4-801E-25F659DD63C5" />
    </informationRequirement>
    <knowledgeRequirement id="_4814C612-4D1C-4450-A503-F5E66D51AF71">
      <requiredKnowledge href="#_C1C3A7D8-522F-4CE3-93D9-A53C39DCE102" />
    </knowledgeRequirement>
    <literalExpression id="_E5194DCE-FF74-4D82-BB60-E16C3AC6FB4F" typeRef="RiskCategory" label="Risk Category">
      <text>if Calculate Risk Score () &lt;= 2 then &quot;HIGH&quot; else if Calculate Risk Score () = 3 then &quot;MEDIUM&quot; else &quot;LOW&quot;</text>
    </literalExpression>
  </decision>
  <decision name="Financial Eligibility" id="_212A45CB-517D-4644-8526-9D2FAEABA063">
    <variable name="Financial Eligibility" id="_57BD33EC-F7F7-41A1-B0CA-1F24B0866800" typeRef="boolean" />
    <informationRequirement id="_40A747BE-300A-4CD4-8957-1FF98BDFB75E">
      <requiredInput href="#_0AC9F0FA-AA7C-4AA4-801E-25F659DD63C5" />
    </informationRequirement>
    <knowledgeRequirement id="_8BAB2610-D7EB-4245-917C-37437B548EC9">
      <requiredKnowledge href="#_3D32D23E-AAE9-42FE-969C-C186E9EB171F" />
    </knowledgeRequirement>
    <conditional id="_67F8BB18-BCB5-4038-A764-4C9E5F543DB8" typeRef="boolean" label="Financial Eligibility">
      <if id="_F584B223-9A88-484D-8656-DF09B3E55DB4">
        <literalExpression id="_F38D8F7E-CB98-4802-B09D-02FAAC827361" label="Expression Name">
          <text>Calculate Financial Strength () &gt; 30000</text>
        </literalExpression>
      </if>
      <then id="_123A070B-2777-43A5-A82A-7EFDB5E84BAC">
        <literalExpression id="_6DCDF410-33C2-4F30-80C0-E3D8AF312ECE" label="Expression Name">
          <text>true</text>
        </literalExpression>
      </then>
      <else id="_EC778A44-9276-4B13-A382-EA7E870B64AE">
        <literalExpression id="_C4CCFCAB-8D43-4F7F-B4B5-9B8BCD771C84" label="Expression Name">
          <text>false</text>
        </literalExpression>
      </else>
    </conditional>
  </decision>
  <businessKnowledgeModel name="Calculate Risk Score" id="_C1C3A7D8-522F-4CE3-93D9-A53C39DCE102">
    <variable name="Calculate Risk Score" id="_1E0F3668-4D00-4F94-9F00-F0087ADEB3D7" typeRef="number" />
    <encapsulatedLogic label="Calculate Risk Score" typeRef="number" id="_83062EAD-77A8-4A4A-9A7E-113434C0B2D9" kind="FEEL">
      <formalParameter id="_E0FF0963-D356-4046-8291-FCA34572FE28" name="LoanApplication" typeRef="LoanApplication" />
      <decisionTable id="_1BB536FE-E5AD-47AC-AAFF-EC37F209CCC3" typeRef="number" hitPolicy="UNIQUE" label="Return">
        <input id="_E7264916-3C9C-4D9C-BAD5-87D60B5A7371">
          <inputExpression id="_BE02D389-8684-4420-82CC-39B7174F9F9E" typeRef="number">
            <text>LoanApplication.Customer.CreditScore</text>
          </inputExpression>
        </input>
        <output id="_67620C92-0841-4841-AF72-4AFA3D1E18D0" />
        <annotation name="Annotations" />
        <rule id="_BC294DA3-A6DA-4E9F-8509-CFE4B50A81F8">
          <inputEntry id="_20EAFEFF-A81A-421A-AF88-DC37AAB54427">
            <text>&lt; 0</text>
          </inputEntry>
          <outputEntry id="_27B767FE-E146-4E5C-81FD-DF2B0A06FB14">
            <text>0</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_EB0F86B9-F2F6-41C8-8A31-61E9CABD8F08">
          <inputEntry id="_E4FFD873-4419-4CC4-BD97-CE160AD61D5F">
            <text>[0 .. 650]</text>
          </inputEntry>
          <outputEntry id="_C72A804B-3DAF-4C0E-BA0C-7A056A378E2A">
            <text>2</text>
          </outputEntry>
          <annotationEntry>
            <text>// Your annotations here</text>
          </annotationEntry>
        </rule>
        <rule id="_F7C50870-122B-4E03-B886-F8BCFE978BC6">
          <inputEntry id="_90382D8B-364C-44AF-8292-E2C38F96F665">
            <text>(650 .. 750]</text>
          </inputEntry>
          <outputEntry id="_CA296BCE-DDAC-4C80-A32C-257B8AEE7EB7">
            <text>3</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
        <rule id="_E852B52B-D4C3-46EA-8C9D-628D92FF77D0">
          <inputEntry id="_73B9139F-8BE5-44E6-BBC7-0669568C7497">
            <text>&gt; 750</text>
          </inputEntry>
          <outputEntry id="_B33C8B78-04C6-4D1C-B707-1A9977078F80">
            <text>4</text>
          </outputEntry>
          <annotationEntry>
            <text></text>
          </annotationEntry>
        </rule>
      </decisionTable>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <businessKnowledgeModel name="Calculate Financial Strength" id="_3D32D23E-AAE9-42FE-969C-C186E9EB171F">
    <variable name="Calculate Financial Strength" id="_3ED70BA6-6E8F-40FF-B00E-C5DD77414F49" typeRef="number" />
    <encapsulatedLogic label="Calculate Financial Strength" typeRef="number" id="_8B401C25-2549-44D7-882E-DAF703A98D1E" kind="FEEL">
      <formalParameter id="_16D89885-D227-4A14-997A-91A86DAE0AC6" name="LoanApplication" typeRef="LoanApplication" />
      <context id="_968365D7-1CFD-4ABB-AB90-8CE38599BBBB" typeRef="number" label="Return">
        <contextEntry id="_E6C6DCC8-3729-4600-B6E1-AE395042BBEB">
          <variable id="_FC0CD879-E2B9-4E90-9E8A-1B875B07930F" name="monthlyIncome" typeRef="number" />
          <literalExpression id="_05C8C62B-EC18-4DB1-99F4-C59E6113BF22" typeRef="number" label="monthlyIncome">
            <text>LoanApplication.Financials.monthlyIncome</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_A1C1A37C-83FE-4ADF-B6E5-E31C681DB776">
          <variable id="_8A76C45C-C771-44EE-A489-57136224ACAD" name="totalIncome" typeRef="number">
            <description></description>
          </variable>
          <literalExpression id="_1E063C62-7644-430D-A487-80C102709F8F" typeRef="number" label="totalIncome">
            <text>monthlyIncome + sum(LoanApplication.Financials.otherIncomes)</text>
          </literalExpression>
        </contextEntry>
        <contextEntry id="_F0CE41E1-1908-4F74-8092-AEDBFF76D265">
          <literalExpression id="_0DB0AD8E-E0E7-4616-B4BB-6063B244498B" typeRef="number" label="Return">
            <text>totalIncome - LoanApplication.Financials.existingEMIs</text>
          </literalExpression>
        </contextEntry>
      </context>
    </encapsulatedLogic>
  </businessKnowledgeModel>
  <inputData name="LoanApplication" id="_0AC9F0FA-AA7C-4AA4-801E-25F659DD63C5">
    <variable name="LoanApplication" id="_3750A22E-DD00-455B-97C3-49D0A60388E9" typeRef="LoanApplication" />
  </inputData>
