  <decision name="Total Income" id="_E1538A7F-AA94-4E43-9C40-72AC80AB653E">
    <variable name="Total Income" id="_0783D7FC-5350-4257-8E96-D069A3863510" typeRef="number" />
    <informationRequirement id="_15BE094D-D29E-44C5-85B0-C06A90F9EFF7">
      <requiredInput href="#_AC402BE8-9FA4-49CF-8E9E-8F8CED1642A2" />
    </informationRequirement>
    <literalExpression id="_2A4E59BC-527F-4EC0-A6F4-708319027A6D" typeRef="number" label="Total Income">
      <text>LoanApplication.Financials.MonthlyIncome + sum(LoanApplication.Financials.OtherIncomes)</text>
    </literalExpression>
  </decision>
  <decision name="EMI Ratio" id="_3CBCD7C1-12A2-4B40-9FE0-3229C7369C94">
    <variable id="_77EC9837-EF9A-43A9-B4D3-52B77E180437" typeRef="number" name="EMI Ratio" />
    <informationRequirement id="_51FB7288-6088-4A26-A321-920C94D4B35B">
      <requiredInput href="#_AC402BE8-9FA4-49CF-8E9E-8F8CED1642A2" />
    </informationRequirement>
    <informationRequirement id="_D9C991FE-997A-45E2-8FD1-ED9978E8667E">
      <requiredDecision href="#_E1538A7F-AA94-4E43-9C40-72AC80AB653E" />
    </informationRequirement>
    <literalExpression id="_849EDE8B-267D-4851-AEB0-6B5FDEBA3E95" typeRef="number" label="EMI Ratio">
      <text>LoanApplication.Financials.ExistingEMIs/Total Income</text>
    </literalExpression>
  </decision>
  <decision name="Risk Category" id="_5A303667-A3C5-4497-8CBB-41E3D58067EA">
    <variable name="Risk Category" id="_01E1A130-61F9-42FD-9ADA-D422E2B0E85B" typeRef="RiskCategory" />
    <informationRequirement id="_50BF703D-8AC3-4E0B-94CE-39339B58EEAE">
      <requiredDecision href="#_3CBCD7C1-12A2-4B40-9FE0-3229C7369C94" />
    </informationRequirement>
    <decisionTable id="_16CA5260-1689-44FD-AA72-EAABEB42FABB" typeRef="RiskCategory" hitPolicy="UNIQUE" label="Risk Category">
      <input id="_E33A1222-5D17-481D-B2A7-94175BFA5E33">
        <inputExpression id="_DE96901A-400E-44BB-9997-E3E096BAF389" typeRef="number">
          <text>EMI Ratio</text>
        </inputExpression>
      </input>
      <output id="_2367EE4F-A25B-443A-9426-B7D54DF9305B" typeRef="RiskCategory" />
      <annotation name="Annotations" />
      <rule id="_2D635647-B3DF-44D5-A2AE-2B67443BD8FA">
        <inputEntry id="_0D68B838-19A6-4F21-B154-AA31701C6F33">
          <text>&lt;= .3</text>
        </inputEntry>
        <outputEntry id="_089E8B56-B430-4139-9010-8006690E2CA3">
          <text>&quot;LOW&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>// Your annotations here</text>
        </annotationEntry>
      </rule>
      <rule id="_3F6B1B41-3802-4D4E-8A0B-52B99150C8DD">
        <inputEntry id="_8533AA96-A3EE-4433-9B4F-23611FB6AA57">
          <text>(.3 .. .5]</text>
        </inputEntry>
        <outputEntry id="_E63F205F-9D16-4088-B527-7C29B9D62D82">
          <text>&quot;MEDIUM&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_E02E1008-8330-4015-BA08-F8BCC3B2AF9E">
        <inputEntry id="_F0A83435-CAB8-43ED-BE98-1BAFC5DE7B8A">
          <text>&gt; .5</text>
        </inputEntry>
        <outputEntry id="_24FC1F87-B169-4D59-9C3C-352588CE6D19">
          <text>&quot;HIGH&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
